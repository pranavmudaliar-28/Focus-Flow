# ─────────────────────────────────────────────────
# Focus Flow Admin — Environment Variables
# ─────────────────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
#
# All variables MUST start with VITE_ so Vite
# can inline them into the client bundle at build time.
# ─────────────────────────────────────────────────

# Firebase Configuration
# Get these from: Firebase Console → Project Settings → Your apps → SDK config
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=1:your_sender_id:web:your_app_id_hash
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Stripe Payment Links
# Stripe publishable key (pk_live_... or pk_test_...) — from Dashboard → Developers → API keys.
# Checkout uses the Stripe.js SDK with the price IDs hardcoded in src/lib/stripe.js.
# Requires "client-only integration" enabled in Stripe Dashboard → Settings → Checkout.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# App URL — used to build Stripe success/cancel redirect URLs
VITE_APP_URL=http://localhost:5173
